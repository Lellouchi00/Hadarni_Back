    "common_mistakes": [
      {
        "mistake": "He go to school.",
        "correction": "He is at school.",
        "explanation": "Use 'is' not the base verb for location/state.",
        "rule": "Use verb to be for states, not action verbs."
      },
      {
        "mistake": "I is a student.",
        "correction": "I am a student.",
        "explanation": "I always takes 'am', not 'is'.",
        "rule": "I → am"
      },
      {
        "mistake": "She are happy.",
        "correction": "She is happy.",
        "explanation": "She is third person singular, so use 'is'.",
        "rule": "He/She/It → is"
      },
      {
        "mistake": "They is teachers.",
        "correction": "They are teachers.",
        "explanation": "They is plural, so use 'are'.",
        "rule": "You/We/They → are"
      },
      {
        "mistake": "You is late.",
        "correction": "You are late.",
        "explanation": "You always takes 'are'.",
        "rule": "You → are"
      },
      {
        "mistake": "We is from Cairo.",
        "correction": "We are from Cairo.",
        "explanation": "We is plural, so use 'are'.",
        "rule": "We → are"
      },
      {
        "mistake": "He no is tall.",
        "correction": "He is not tall.",
        "explanation": "Put 'not' after 'is', not before it.",
        "rule": "Subject + is/are/am + not"
      },
      {
        "mistake": "I not a student.",
        "correction": "I am not a student.",
        "explanation": "Don't omit the verb 'to be'.",
        "rule": "Never drop am/is/are in negative sentences."
      },
      {
        "mistake": "You not from Egypt?",
        "correction": "Are you not from Egypt?",
        "explanation": "Invert the subject and verb for questions.",
        "rule": "Is/Are/Am + subject + complement?"
      },
      {
        "mistake": "He is doctor.",
        "correction": "He is a doctor.",
        "explanation": "Use 'a/an' before singular countable nouns.",
        "rule": "Subject + is/are + a/an + noun"
      },
      {
        "mistake": "They are student.",
        "correction": "They are students.",
        "explanation": "Use plural noun after 'are' with plural subjects.",
        "rule": "Plural subject → plural noun"
      },
      {
        "mistake": "She no is my friend.",
        "correction": "She is not my friend.",
        "explanation": "Negation goes after the verb, not before.",
        "rule": "Negative: is/are/am + not"
      },
      {
        "mistake": "Is go he to school?",
        "correction": "Is he at school?",
        "explanation": "Don't add extra verbs after verb to be in questions.",
        "rule": "Question: Is/Are/Am + subject + complement?"
      },
      {
        "mistake": "He tired very.",
        "correction": "He is very tired.",
        "explanation": "Place 'very' before the adjective.",
        "rule": "Subject + is/are + very + adjective"
      },
      {
        "mistake": "It's a book. It's my.",
        "correction": "It's a book. It's mine.",
        "explanation": "Use possessive pronouns, not possessive adjectives, alone.",
        "rule": "Use possessive pronouns without nouns."
      },
      {
        "mistake": "I'm student.",
        "correction": "I'm a student.",
        "explanation": "Always use 'a/an' before singular countable nouns.",
        "rule": "Article needed before countable singular nouns."
      },
      {
        "mistake": "Where you are?",
        "correction": "Where are you?",
        "explanation": "Invert subject and verb after question words.",
        "rule": "Wh-word + is/are/am + subject?"
      }
    ],
    "mini_rules": [
      {
        "title": "I am",
        "rule": "I → am",
        "example": "I am happy."
      },
      {
        "title": "He/She/It is",
        "rule": "He/She/It → is",
        "example": "She is a doctor."
      },
      {
        "title": "You/We/They are",
        "rule": "You/We/They → are",
        "example": "They are students."
      },
      {
        "title": "Negative",
        "rule": "Add 'not' after am/is/are",
        "example": "I am not tired."
      },
      {
        "title": "Question",
        "rule": "Put am/is/are before the subject",
        "example": "Are you ready?"
      },
      {
        "title": "Contractions",
        "rule": "Join subject + verb with apostrophe",
        "example": "I'm, he's, she's, it's, you're, we're, they're"
      }
    ],
